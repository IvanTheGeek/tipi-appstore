{
  "schemaVersion": 2,
  "$schema": "https://schemas.runtipi.io/v2/dynamic-compose.json",
  "services": [
    {
      "name": "garage",
      "image": "dxflrs/garage:v1.3.1",
      "isMain": true,
      "internalPort": 3900,
      "addPorts": [
        {
          "hostPort": 3903,
          "containerPort": 3903,
          "tcp": true
        }
      ],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data",
          "containerPath": "/var/lib/garage/data"
        },
        {
          "hostPath": "${APP_DATA_DIR}/meta",
          "containerPath": "/var/lib/garage/meta"
        },
        {
          "hostPath": "${APP_DATA_DIR}/config/garage.toml",
          "containerPath": "/etc/garage.toml",
          "readOnly": true
        }
      ],
      "restart": "unless-stopped",
      "extraLabels": {
        "traefik.enable": "true",
        "traefik.http.middlewares.garage-s3-redirect.redirectscheme.scheme": "https",
        "traefik.http.routers.garage-s3-insecure.rule": "Host(`s3.ivanthegeek.com`)",
        "traefik.http.routers.garage-s3-insecure.entrypoints": "web",
        "traefik.http.routers.garage-s3-insecure.service": "garage-s3-svc",
        "traefik.http.routers.garage-s3-insecure.middlewares": "garage-s3-redirect",
        "traefik.http.routers.garage-s3.rule": "Host(`s3.ivanthegeek.com`)",
        "traefik.http.routers.garage-s3.entrypoints": "websecure",
        "traefik.http.routers.garage-s3.service": "garage-s3-svc",
        "traefik.http.routers.garage-s3.tls.certresolver": "myresolver",
        "traefik.http.services.garage-s3-svc.loadbalancer.server.port": "3900",
        "traefik.http.middlewares.garage-web-redirect.redirectscheme.scheme": "https",
        "traefik.http.routers.garage-web-insecure.rule": "Host(`public.artifacts.ivanthegeek.com`)",
        "traefik.http.routers.garage-web-insecure.entrypoints": "web",
        "traefik.http.routers.garage-web-insecure.service": "garage-web-svc",
        "traefik.http.routers.garage-web-insecure.middlewares": "garage-web-redirect",
        "traefik.http.routers.garage-web.rule": "Host(`public.artifacts.ivanthegeek.com`)",
        "traefik.http.routers.garage-web.entrypoints": "websecure",
        "traefik.http.routers.garage-web.service": "garage-web-svc",
        "traefik.http.routers.garage-web.tls.certresolver": "myresolver",
        "traefik.http.services.garage-web-svc.loadbalancer.server.port": "3902"
      }
    }
  ]
}
