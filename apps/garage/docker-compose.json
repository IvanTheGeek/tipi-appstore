{
  "schemaVersion": 2,
  "$schema": "https://schemas.runtipi.io/v2/dynamic-compose.json",
  "services": [
    {
      "name": "garage",
      "image": "dxflrs/garage:v1.3.1",
      "isMain": true,
      "internalPort": 3900,
      "addPorts": [
        {
          "hostPort": 3903,
          "containerPort": 3903,
          "tcp": true
        }
      ],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data",
          "containerPath": "/var/lib/garage/data"
        },
        {
          "hostPath": "${APP_DATA_DIR}/meta",
          "containerPath": "/var/lib/garage/meta"
        },
        {
          "hostPath": "${APP_DATA_DIR}/config/garage.toml",
          "containerPath": "/etc/garage.toml",
          "readOnly": true
        }
      ],
      "restart": "unless-stopped"
    }
  ]
}
