{
  "schemaVersion": 2,
  "$schema": "https://schemas.runtipi.io/v2/dynamic-compose.json",
  "services": [
    {
      "name": "laundrylog",
      "image": "fholzer/nginx-brotli:latest",
      "isMain": true,
      "internalPort": 80,
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/www",
          "containerPath": "/usr/share/nginx/html",
          "readOnly": true
        },
        {
          "hostPath": "${APP_DATA_DIR}/conf/default.conf",
          "containerPath": "/etc/nginx/conf.d/default.conf",
          "readOnly": true
        }
      ],
      "extraLabels": {
        "traefik.enable": "true",
        "traefik.http.middlewares.laundrylog-redirect.redirectscheme.scheme": "https",
        "traefik.http.routers.laundrylog-insecure.rule": "Host(`laundrylog.ivanthegeek.com`)",
        "traefik.http.routers.laundrylog-insecure.entrypoints": "web",
        "traefik.http.routers.laundrylog-insecure.service": "laundrylog-svc",
        "traefik.http.routers.laundrylog-insecure.middlewares": "laundrylog-redirect",
        "traefik.http.routers.laundrylog.rule": "Host(`laundrylog.ivanthegeek.com`)",
        "traefik.http.routers.laundrylog.entrypoints": "websecure",
        "traefik.http.routers.laundrylog.service": "laundrylog-svc",
        "traefik.http.routers.laundrylog.tls.certresolver": "myresolver",
        "traefik.http.services.laundrylog-svc.loadbalancer.server.port": "80"
      }
    }
  ]
}
