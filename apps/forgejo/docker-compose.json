{
  "schemaVersion": 2,
  "$schema": "https://schemas.runtipi.io/v2/dynamic-compose.json",
  "services": [
    {
      "name": "forgejo",
      "image": "codeberg.org/forgejo/forgejo:14.0.3",
      "isMain": true,
      "internalPort": 3000,
      "addPorts": [
        {
          "hostPort": 222,
          "containerPort": 22
        }
      ],
      "environment": [
        {
          "key": "USER_UID",
          "value": "1000"
        },
        {
          "key": "USER_GID",
          "value": "1000"
        },
        {
          "key": "FORGEJO__database__DB_TYPE",
          "value": "postgres"
        },
        {
          "key": "FORGEJO__database__HOST",
          "value": "forgejo-db:5432"
        },
        {
          "key": "FORGEJO__database__NAME",
          "value": "forgejo"
        },
        {
          "key": "FORGEJO__database__USER",
          "value": "forgejo"
        },
        {
          "key": "FORGEJO__database__PASSWD",
          "value": "${FORGEJO_DB_PASSWORD}"
        },
        {
          "key": "FORGEJO__server__DOMAIN",
          "value": "forgejo.ivanthegeek.com"
        },
        {
          "key": "FORGEJO__server__SSH_DOMAIN",
          "value": "forgejo.ivanthegeek.com"
        },
        {
          "key": "FORGEJO__server__ROOT_URL",
          "value": "https://forgejo.ivanthegeek.com"
        },
        {
          "key": "FORGEJO__server__SSH_PORT",
          "value": "222"
        },
        {
          "key": "FORGEJO__server__READ_TIMEOUT",
          "value": "0"
        },
        {
          "key": "FORGEJO__server__WRITE_TIMEOUT",
          "value": "0"
        },
        {
          "key": "FORGEJO__server__LFS_MAX_BLOB_SIZE",
          "value": "0"
        },
        {
          "key": "FORGEJO__attachment__MAX_SIZE",
          "value": "2048"
        }
      ],
      "extraLabels": {
        "traefik.enable": "true",
        "traefik.http.middlewares.forgejo-redirect.redirectscheme.scheme": "https",
        "traefik.http.routers.forgejo-insecure.rule": "Host(`forgejo.ivanthegeek.com`)",
        "traefik.http.routers.forgejo-insecure.entrypoints": "web",
        "traefik.http.routers.forgejo-insecure.service": "forgejo-svc",
        "traefik.http.routers.forgejo-insecure.middlewares": "forgejo-redirect",
        "traefik.http.routers.forgejo.rule": "Host(`forgejo.ivanthegeek.com`)",
        "traefik.http.routers.forgejo.entrypoints": "websecure",
        "traefik.http.routers.forgejo.service": "forgejo-svc",
        "traefik.http.routers.forgejo.tls.certresolver": "myresolver",
        "traefik.http.services.forgejo-svc.loadbalancer.server.port": "3000",
        "traefik.docker.network": "runtipi_tipi_main_network"
      },
      "dependsOn": ["forgejo-db"],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data/forgejo",
          "containerPath": "/data"
        }
      ]
    },
    {
      "name": "forgejo-db",
      "image": "postgres:14",
      "environment": [
        {
          "key": "POSTGRES_USER",
          "value": "forgejo"
        },
        {
          "key": "POSTGRES_PASSWORD",
          "value": "${FORGEJO_DB_PASSWORD}"
        },
        {
          "key": "POSTGRES_DB",
          "value": "forgejo"
        }
      ],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data/postgres",
          "containerPath": "/var/lib/postgresql/data"
        }
      ]
    }
  ]
}
